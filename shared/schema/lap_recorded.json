{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LapRecorded",
  "type": "object",
  "required": ["lapId", "userId", "trackId", "sessionType", "lapTimeMs", "isValid", "isRankingEligible"],
  "properties": {
    "lapId": {
      "type": "string",
      "format": "uuid",
      "description": "생성된 랩 기록의 고유 GUID"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "기록 주행자의 고유 GUID"
    },
    "trackId": {
      "type": "string",
      "format": "uuid",
      "description": "트랙 고유 GUID"
    },
    "sessionType": {
      "type": "string",
      "description": "게임 내 세션 모드"
    },
    "lapTimeMs": {
      "type": "integer",
      "description": "기록된 랩타임 (밀리초)"
    },
    "isValid": {
      "type": "boolean",
      "description": "랩 유효 여부"
    },
    "isRankingEligible": {
      "type": "boolean",
      "description": "랭킹 등록 적격 여부"
    }
  }
}
