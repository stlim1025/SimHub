{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SectorCompleted",
  "type": "object",
  "required": ["sessionRef", "lapNumber", "sectorNumber", "sectorTimeMs"],
  "properties": {
    "sessionRef": {
      "type": "string",
      "description": "연관된 게임 세션 식별자"
    },
    "lapNumber": {
      "type": "integer",
      "minimum": 1,
      "description": "해당 랩 번호"
    },
    "sectorNumber": {
      "type": "integer",
      "minimum": 1,
      "description": "주행 완료된 섹터 번호 (예: F1 기준 1, 2)"
    },
    "sectorTimeMs": {
      "type": "integer",
      "minimum": 1,
      "description": "섹터 통과 소요 시간 (밀리초 단위)"
    }
  }
}
