<Window x:Class="SimCenter.Agent.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimCenter.Agent.Tray"
        mc:Ignorable="d"
        Title="SimCenter Agent" Height="500" Width="440"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E22">
    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A8A93" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8EC" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 상태 헤더: 신호등 점 + 상태 텍스트 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <Ellipse x:Name="StatusDot" Width="18" Height="18" Fill="#DC3545" VerticalAlignment="Center" />
            <TextBlock x:Name="StatusText" Text="미연결" Foreground="#E8E8EC"
                       FontSize="22" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Grid.Row="1" x:Name="StatusHint" Style="{StaticResource Label}"
                   Text="게임 텔레메트리 수신을 기다리는 중…" Margin="30,0,0,16" />

        <!-- 상세 지표 -->
        <StackPanel Grid.Row="2">
            <Grid Margin="0,4">
                <TextBlock Text="UDP 포트" Style="{StaticResource Label}" />
                <TextBlock x:Name="PortValue" Style="{StaticResource Value}" Text="—" />
            </Grid>
            <Grid Margin="0,4">
                <TextBlock Text="수신 패킷" Style="{StaticResource Label}" />
                <TextBlock x:Name="PacketsValue" Style="{StaticResource Value}" Text="0" />
            </Grid>
            <Grid Margin="0,4">
                <TextBlock Text="마지막 수신" Style="{StaticResource Label}" />
                <TextBlock x:Name="LastSeenValue" Style="{StaticResource Value}" Text="—" />
            </Grid>
            <Grid Margin="0,4">
                <TextBlock Text="감지 패킷 포맷" Style="{StaticResource Label}" />
                <TextBlock x:Name="PacketFormatValue" Style="{StaticResource Value}" Text="—" />
            </Grid>
            <Border x:Name="ErrorBox" Background="#3A1D22" CornerRadius="4" Padding="10,8" Margin="0,10,0,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" Foreground="#F1959E" FontSize="12" TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <!-- 실시간 수신 그래프 -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <TextBlock Text="실시간 수신 (pkt/s)" Style="{StaticResource Label}" />
                <TextBlock x:Name="RateValue" Style="{StaticResource Value}" Text="0" />
            </Grid>
            <Border Grid.Row="1" Background="#17171A" CornerRadius="6" Padding="6">
                <Grid x:Name="ChartArea" ClipToBounds="True" SizeChanged="ChartArea_SizeChanged">
                    <!-- 채움(면적) + 상단 라인. Points는 코드비하인드에서 갱신 -->
                    <Polygon x:Name="RateFill" Fill="#263FB950" />
                    <Polyline x:Name="RateLine" Stroke="#3FB950" StrokeThickness="1.5"
                              StrokeLineJoin="Round" />
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="4" Style="{StaticResource Label}" FontSize="11" Margin="0,10,0,0"
                   Text="창을 닫아도 트레이에서 계속 실행됩니다. 종료는 트레이 아이콘 메뉴에서." />
    </Grid>
</Window>
